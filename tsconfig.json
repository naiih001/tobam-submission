{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["ESNext"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force",
    "allowJs": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "index.ts", "tests/**/*"]
}
